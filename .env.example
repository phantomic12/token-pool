# token-pool environment configuration

# Required: secret key for encrypting API keys and signing JWTs
# Generate with: head -c 32 /dev/urandom | base64
APP_SECRET=

# SQLite database path (use /data/router.db in Docker)
DATABASE_URL=data/router.db

# Server bind
PORT=8000
HOST=0.0.0.0

# Transcoding hardware acceleration: auto | nvenc | amf | qsv | cpu
TRANSCODE_HW=auto

# Model metadata refresh interval in seconds (default 1 hour)
MODELS_REFRESH_INTERVAL=3600

# Optional: set admin password on first run (otherwise random password generated)
# ADMIN_PASSWORD=
