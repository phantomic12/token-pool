{
  "name": "token-pool",
  "version": "0.1.0",
  "description": "Self-hosted LLM routing proxy with fusion, tiers, free-provider rate limits, and WebUI",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.1.0",
    "@fastify/jwt": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.0",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0",
    "tsc-alias": "^1.7.0"
  }
}
